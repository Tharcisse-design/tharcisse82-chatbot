
body {
    font-family: Arial, sans-serif;
    background-color: #f4f6f8;
    text-align: center;
    padding: 30px;
}

h1 {
    color: #2563EB;
}

h2 {
    color: #333333;
}

p {
    color: #555555;
    font-size: 18px;
}

ul {
    list-style-position: inside;
    padding: 0;
}

li {
    margin: 10px 0;
}

button {
    background-color: #F97316;
    color: white;
    border: none;
    padding: 15px 25px;
    font-size: 18px;
    border-radius: 8px;
}

button:hover {
    cursor: pointer;
}